{
  "routes": [
    { "handle": "filesystem" },

    { "src": "^/$", "dest": "/public/index.html" },
    { "src": "^/home$", "dest": "/public/home.html" },
    { "src": "^/login$", "dest": "/public/login.html" },
    { "src": "^/schedule$", "dest": "/public/schedule.html" },
    { "src": "^/room/(.*)", "dest": "/public/room.html" }
  ]
}